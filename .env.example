# Copy to your NestJS project's .env (this repo ships only the ES infra).
# NestJS runs on the HOST, so it reaches Elasticsearch via localhost.
ELASTICSEARCH_NODE=http://localhost:9200

# Security is disabled in dev mode, so username/password are NOT required.
# They are listed here only to show where they would go in production.
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
